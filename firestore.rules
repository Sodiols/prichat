rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSystemAdmin() {
      return isSignedIn()
        && request.auth.token.email == "itssayem2023@gmail.com";
    }

    function roomData(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)).data;
    }

    function canOpenRoom(roomId) {
      return isSystemAdmin()
        || request.auth.uid in roomData(roomId).members
        || request.auth.uid in roomData(roomId).admins;
    }

    function canManageRoom(roomId) {
      return isSystemAdmin()
        || request.auth.uid in roomData(roomId).admins;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /rooms/{roomId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.admins == [request.auth.uid]
        && request.resource.data.members == [request.auth.uid];

      allow update: if isSignedIn() && (
        isSystemAdmin()
        || request.auth.uid in resource.data.admins
        || isSelfJoin()
        || isSelfLeave()
        || isSystemAdminJoinAsAdmin()
        || isSystemAdminJoinNormal()
      );

      allow delete: if isSignedIn()
        && (isSystemAdmin() || request.auth.uid in resource.data.admins);

      function isSelfJoin() {
        return resource.data.privacy in ["public", "passcode"]
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["members"])
          && request.resource.data.members.hasAll(resource.data.members)
          && request.resource.data.members.hasAny([request.auth.uid])
          && request.resource.data.members.size() == resource.data.members.size() + 1;
      }

      function isSelfLeave() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(["members"])
          && resource.data.members.hasAny([request.auth.uid])
          && !request.resource.data.members.hasAny([request.auth.uid])
          && resource.data.members.hasAll(request.resource.data.members)
          && request.resource.data.members.size() == resource.data.members.size() - 1;
      }

      function isSystemAdminJoinAsAdmin() {
        return isSystemAdmin()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["admins"])
          && request.resource.data.admins.hasAll(resource.data.admins)
          && request.resource.data.admins.hasAny([request.auth.uid])
          && request.resource.data.admins.size() == resource.data.admins.size() + 1;
      }

      function isSystemAdminJoinNormal() {
        return isSystemAdmin()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["members"])
          && request.resource.data.members.hasAll(resource.data.members)
          && request.resource.data.members.hasAny([request.auth.uid])
          && request.resource.data.members.size() == resource.data.members.size() + 1;
      }

      match /joinRequests/{uid} {
        allow create: if isSignedIn()
          && request.auth.uid == uid
          && request.resource.data.uid == request.auth.uid;

        allow read: if isSignedIn() && (
          request.auth.uid == uid
          || canManageRoom(roomId)
        );

        allow delete: if isSignedIn() && (
          request.auth.uid == uid
          || canManageRoom(roomId)
        );

        allow update: if false;
      }

      match /messages/{messageId} {
        allow read: if isSignedIn() && canOpenRoom(roomId);

        allow create: if isSignedIn()
          && canOpenRoom(roomId)
          && request.auth.uid == request.resource.data.uid
          && request.resource.data.keys().hasAll(["text", "type", "uid", "displayName", "createdAt"])
          && request.resource.data.keys().hasOnly([
            "text",
            "type",
            "mediaUrl",
            "fileName",
            "fileMimeType",
            "fileSize",
            "durationSeconds",
            "uid",
            "displayName",
            "photoURL",
            "createdAt",
            "replyTo"
          ])
          && request.resource.data.type in ["text", "image", "video", "voice"]
          && request.resource.data.text is string
          && (request.resource.data.text.size() > 0 || request.resource.data.type in ["image", "video", "voice"])
          && (
            request.resource.data.type == "text"
            || (
              request.resource.data.mediaUrl is string
              && request.resource.data.mediaUrl.size() > 0
              && request.resource.data.fileName is string
              && request.resource.data.fileMimeType is string
              && request.resource.data.fileSize is int
              && request.resource.data.fileSize < 100 * 1024 * 1024
              && (
                request.resource.data.type != "voice"
                || (
                  request.resource.data.durationSeconds is int
                  && request.resource.data.durationSeconds >= 0
                  && request.resource.data.durationSeconds < 3600
                )
              )
            )
          );

        allow update: if isSignedIn()
          && canOpenRoom(roomId)
          && (request.auth.uid == resource.data.uid || isSystemAdmin())
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["text", "editedAt"])
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0;

        allow delete: if isSignedIn()
          && canOpenRoom(roomId)
          && (request.auth.uid == resource.data.uid || isSystemAdmin());
      }

      match /calls/{callId} {
        allow read: if isSignedIn() && canOpenRoom(roomId);

        allow create: if isSignedIn()
          && canOpenRoom(roomId)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.status == "active"
          && request.resource.data.type in ["audio", "video"];

        allow update: if isSignedIn()
          && canOpenRoom(roomId)
          && (
            isSystemAdmin()
            || request.auth.uid == resource.data.createdBy
            || request.auth.uid in roomData(roomId).admins
          );

        allow delete: if false;

        match /participants/{uid} {
          allow read: if isSignedIn() && canOpenRoom(roomId);

          allow create, update: if isSignedIn()
            && canOpenRoom(roomId)
            && (request.auth.uid == uid || isSystemAdmin())
            && request.resource.data.uid == uid;

          allow delete: if false;
        }

        match /peers/{peerId} {
          allow read, create, update: if isSignedIn() && canOpenRoom(roomId);
          allow delete: if false;

          match /offerCandidates/{candidateId} {
            allow read, create: if isSignedIn() && canOpenRoom(roomId);
            allow update, delete: if false;
          }

          match /answerCandidates/{candidateId} {
            allow read, create: if isSignedIn() && canOpenRoom(roomId);
            allow update, delete: if false;
          }
        }
      }
    }
  }
}
